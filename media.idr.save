main : IO ()
main = do
  putStrLn "Nota 1: "
  nota1 <- getLine
  let n1 = cast nota1 : Double
  putStrLn "Nota 2: "
  nota2 <- getLine
  let n2 = cast nota2 : Double
  putStrLn ("Media: " ++ show ((n1 + n2) / 2.0)main : IO ()
